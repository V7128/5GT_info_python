





    
from PyQt6 import QtWidgets, QtGui, QtCore
from PyQt6.QtWidgets import QWidget,QLabel,QPushButton,QLineEdit, QVBoxLayout
from math import sqrt
import sys 

class Gui(QtWidgets.QMainWindow):
    def __init__(self):
        super(Gui, self).__init__()
        # 1. Créer le widget conteneur central
        central_widget = QWidget()

        # 2. Créer un layout
        layout = QVBoxLayout()

        #3 création des widget et placement dans le layout
        label=QLabel("dans la fonction y=ax²+bx+c : ")
        layout.addWidget(label)

        label=QLabel("quelle est la valeur de a ?")
        layout.addWidget(label)
        
        self.line_edit_a= QLineEdit()
        layout.addWidget(self.line_edit_a)

        #label et line edit pour b
        label=QLabel("quelle est la valeur de b ?")
        layout.addWidget(label)
        
        self.line_edit_b= QLineEdit()
        layout.addWidget(self.line_edit_b)

        #label et line edit pour c
        label=QLabel("<p>quelle est la valeur de <b>c<b/> ?<p/>")
        layout.addWidget(label)
        
        self.line_edit_c= QLineEdit()
        layout.addWidget(self.line_edit_c)

        button=QPushButton(" résoudre")
        layout.addWidget(button)

        central_widget.setLayout(layout)
        self.setCentralWidget(central_widget)

    def resoudre(self):
        a=self.line_edit_a.text()
        b=self.line_edit_b.text()
        c=self.line_edit_c.text()

        a=float(a)
        b=float(b)
        c=float(c)

        delta=b**2-4*a*c 

        if delta<0: 
            text="<p> il n'y a <b>pas de racine</b> à cette fonction. </p>"

        elif delta==0:
            racine=-b/(2*a)
            text=f"<p>il y a <b>une racine</b> à cette fonction. </p>"
            text+=f"<p>elle vaut :"
            text+=f"<ul><li>{round(racine,4)}</li></ul></p>"

        elif delta>0:
            racine_1=(-b+sqrt(delta))/(2*a)
            racine_2=(-b-sqrt(delta))/(2*a)
            text=f"<p>il y a <b>une racine</b> à cette fonction. </p>"
            text+=f"<p>elles valent :"
            text+=f"<ul><li>{round(racine_1,4)}</li>"
            text+=f"<li>{round(racine_2,4)}</li></ul></p>"
